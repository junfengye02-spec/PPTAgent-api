# ============================================================
#  PPTAgent API Server 环境变量配置
#  复制本文件为 .env 并填入实际值:  cp .env.example .env
# ============================================================

# ---------- LLM 配置 (必填) ----------
LLM_API_KEY=sk-your-api-key-here
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen2.5-72B-Instruct
LLM_LONG_CONTEXT_MODEL=Qwen/Qwen2.5-72B-Instruct-128K

# ---------- 可选服务 ----------
TAVILY_API_KEY=
METASO_API_KEY=
MINERU_API_KEY=

# ---------- 服务器配置 ----------
API_HOST=0.0.0.0
API_PORT=8000
# 公网访问地址（留空则启动时自动探测公网 IP）
PUBLIC_URL=
PPTAGENT_CMD=pptagent
